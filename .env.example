# ── Robinhood credentials ─────────────────────────────────────────────────────
ROBINHOOD_USERNAME=your_email@example.com
ROBINHOOD_PASSWORD=your_password
# MFA / TOTP secret (base-32 string from Robinhood 2-FA setup)
ROBINHOOD_MFA_SECRET=

# ── Trading mode ──────────────────────────────────────────────────────────────
# "paper" (default, safe) or "live" (real money — set deliberately)
TRADING_MODE=paper

# ── Paper trading starting capital ────────────────────────────────────────────
PAPER_STARTING_CAPITAL=10000.00

# ── Risk limits (override defaults from settings.py if needed) ────────────────
MAX_DAILY_LOSS=200.00
MAX_CAPITAL_PER_TRADE_PCT=0.10
MAX_OPEN_POSITIONS=3

# ── Monitoring ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
